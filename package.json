{
  "name": "@deluksic/opencv-calibration-wasm",
  "version": "0.2.2",
  "description": "Browser-ready OpenCV calibrateCameraRO WASM package",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./wasm/*": "./dist/wasm/*"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:ts": "rm -f dist/index.js dist/index.d.ts && tsc -p tsconfig.json",
    "build:opencv": "bash ./scripts/build-opencv.sh",
    "build:wasm": "bash ./scripts/build-wrapper.sh",
    "build": "pnpm build:ts && pnpm build:wasm",
    "example": "node ./examples/run-fixture.mjs"
  },
  "keywords": [
    "opencv",
    "wasm",
    "camera-calibration",
    "calibrateCameraRO"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
